{
  "entities": {
    "Blog": {
      "title": "Blog",
      "description": "A blog post.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the blog post"
        },
        "content": {
          "type": "string",
          "description": "The content of the blog post (text or markdown)"
        },
        "link": {
          "type": "string",
          "description": "Optional external link"
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "private"],
          "description": "Whether this blog is public or private"
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL to the main blog image"
        },
        "imageUrls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Multiple images for the blog"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags for the blog"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["title", "content", "visibility", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project with a name and a link.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The name of the project"
        },
        "link": {
          "type": "string",
          "description": "The URL to the project or embedding"
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "private"],
          "description": "Whether this project is public or private"
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL to the project image"
        },
        "imageUrls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "The URLs to the project multiple images"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags for the project"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["title", "link", "visibility", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact form message from a visitor.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender"
        },
        "email": {
          "type": "string",
          "description": "Email of the sender"
        },
        "message": {
          "type": "string",
          "description": "Message content"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "The collection of portfolio projects."
    },
    "blogs": {
      "schema": "Blog",
      "description": "The collection of blog posts."
    },
    "messages": {
      "schema": "Message",
      "description": "The collection of contact messages."
    }
  }
}
